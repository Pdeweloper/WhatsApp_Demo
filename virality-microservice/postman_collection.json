{
  "info": {
    "name": "Virality Microservice",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Post",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": 1,\n  \"content\": \"Hello World!\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/posts",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "posts"
          ]
        }
      }
    },
    {
      "name": "Add Comment",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": 2,\n  \"content\": \"Great post!\",\n  \"targetCommentId\": null\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/posts/1/comments",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "posts",
            "1",
            "comments"
          ]
        }
      }
    },
    {
      "name": "Like Post",
      "request": {
